---
import Layout from '../layouts/Layout.astro';

const kontakt = {
  telefon: '732 365 945',
  email: 'info@zubarka-trutnov.cz',
  adresa: 'Úpské nábřeží 379, 541 01 Trutnov',
  ico: '65197976',
  pracovniDoba: [
    { den: 'Pondělí', cas: '7:00 – 13:00' },
    { den: 'Úterý', cas: '9:00 – 17:00' },
    { den: 'Středa', cas: '8:00 – 14:00' },
    { den: 'Čtvrtek', cas: '8:00 – 14:00' },
    { den: 'Pátek', cas: '8:00 – 13:00' },
    { den: 'Sobota – Neděle', cas: 'Zavřeno 😴' },
  ],
};
---
<Layout title="Kontakt" description="Kontaktujte zubní ordinaci MUDr. Věry Holubcové v Trutnově. Tel: 732 365 945. Úpské nábřeží 379.">

  <!-- Header -->
  <section class="bg-cream overflow-hidden relative py-20 px-6">
    <div class="absolute top-0 right-0 w-80 h-80 bg-primary-200 rounded-full opacity-30 translate-x-1/3 -translate-y-1/3 blur-3xl pointer-events-none"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-6">✉️ Napište nebo zavolejte!</div>
      <h1 class="text-6xl md:text-7xl font-black text-dark leading-none mb-6 max-w-xl">
        Objednejte se<br/>
        <span class="text-primary-500">k nám!</span> 😊
      </h1>
      <p class="text-gray-600 text-xl max-w-lg leading-relaxed">
        Máte otázku nebo chcete termín? Napište nám! Odpovídáme rychle a rádi.
      </p>
    </div>
  </section>

  <!-- Kontaktní sekce -->
  <section class="section">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12">

      <!-- Formulář -->
      <div>
        <div class="pill mb-6">📝 Napište nám</div>
        <form id="contact-form" class="space-y-5" novalidate>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="jmeno" class="block text-sm font-extrabold text-dark mb-2">Vaše jméno *</label>
              <input
                type="text"
                id="jmeno"
                name="jmeno"
                required
                placeholder="Jan Novák"
                class="w-full border-2 border-gray-200 rounded-3xl px-5 py-4 text-sm text-dark placeholder:text-gray-300 font-semibold focus:outline-none focus:border-primary-400 transition"
              />
            </div>
            <div>
              <label for="telefon" class="block text-sm font-extrabold text-dark mb-2">Telefon</label>
              <input
                type="tel"
                id="telefon"
                name="telefon"
                placeholder="732 365 945"
                class="w-full border-2 border-gray-200 rounded-3xl px-5 py-4 text-sm text-dark placeholder:text-gray-300 font-semibold focus:outline-none focus:border-primary-400 transition"
              />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-extrabold text-dark mb-2">E-mail *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jan@email.cz"
              class="w-full border-2 border-gray-200 rounded-3xl px-5 py-4 text-sm text-dark placeholder:text-gray-300 font-semibold focus:outline-none focus:border-primary-400 transition"
            />
          </div>
          <div>
            <label for="zprava" class="block text-sm font-extrabold text-dark mb-2">Zpráva *</label>
            <textarea
              id="zprava"
              name="zprava"
              required
              rows="5"
              placeholder="Chci se objednat na prohlídku, mám bolest zubu... Nebojte se napsat! 😊"
              class="w-full border-2 border-gray-200 rounded-3xl px-5 py-4 text-sm text-dark placeholder:text-gray-300 font-semibold focus:outline-none focus:border-primary-400 transition resize-none"
            ></textarea>
          </div>
          <button type="submit" id="submit-btn" class="btn-primary w-full text-center py-5 text-base rounded-3xl">
            Odeslat zprávu 🦷
          </button>
          <div id="form-status" class="text-sm mt-2 hidden"></div>
          <p class="text-xs text-gray-400 text-center">* Povinné pole. Odpovídáme co nejdříve!</p>
        </form>
      </div>

      <!-- Kontaktní info -->
      <div class="flex flex-col gap-6">
        <div class="pill mb-2">📍 Najdete nás tady</div>

        <a href={`tel:${kontakt.telefon.replace(/\s/g, '')}`}
           class="flex items-center gap-5 bg-gray-50 rounded-4xl p-6 hover:bg-primary-50 transition-colors group border-2 border-transparent hover:border-primary-200">
          <div class="w-14 h-14 bg-primary-500 rounded-3xl flex items-center justify-center text-2xl flex-shrink-0">📞</div>
          <div>
            <div class="text-xs font-black text-gray-400 uppercase tracking-wide">Zavolejte nám</div>
            <div class="font-black text-dark text-xl group-hover:text-primary-500 transition-colors">{kontakt.telefon}</div>
          </div>
        </a>

        <a href={`mailto:${kontakt.email}`}
           class="flex items-center gap-5 bg-gray-50 rounded-4xl p-6 hover:bg-primary-50 transition-colors group border-2 border-transparent hover:border-primary-200">
          <div class="w-14 h-14 bg-accent rounded-3xl flex items-center justify-center text-2xl flex-shrink-0">✉️</div>
          <div>
            <div class="text-xs font-black text-gray-400 uppercase tracking-wide">Napište e-mail</div>
            <div class="font-black text-dark text-xl group-hover:text-primary-500 transition-colors">{kontakt.email}</div>
          </div>
        </a>

        <div class="flex items-center gap-5 bg-gray-50 rounded-4xl p-6 border-2 border-transparent">
          <div class="w-14 h-14 bg-primary-100 rounded-3xl flex items-center justify-center text-2xl flex-shrink-0">📍</div>
          <div>
            <div class="text-xs font-black text-gray-400 uppercase tracking-wide">Adresa</div>
            <div class="font-black text-dark text-lg">{kontakt.adresa}</div>
            <div class="text-xs text-gray-400 font-bold mt-1">V blízkosti parkoviště Lidl</div>
          </div>
        </div>

        <!-- Pracovní doba -->
        <div class="bg-gray-50 rounded-4xl p-8 border-2 border-gray-100">
          <div class="font-black text-dark text-lg mb-4">🕐 Ordinační hodiny</div>
          <div class="space-y-3">
            {kontakt.pracovniDoba.map(d => (
              <div class="flex justify-between text-sm">
                <span class="font-bold text-gray-500">{d.den}</span>
                <span class="font-extrabold text-dark">{d.cas}</span>
              </div>
            ))}
          </div>
          <div class="mt-6 pt-4 border-t-2 border-gray-200 text-xs text-gray-400 font-bold">
            IČO: {kontakt.ico}
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Odesílám...';
    status.className = 'text-sm mt-2 hidden';

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
      const json = await res.json();
      if (json.ok) {
        form.reset();
        status.textContent = '✓ Zpráva odeslána. Ozveme se co nejdříve!';
        status.className = 'text-sm mt-2 text-green-600 font-medium';
        btn.textContent = 'Odesláno';
      } else {
        status.textContent = json.error ?? 'Chyba. Zkuste to prosím znovu.';
        status.className = 'text-sm mt-2 text-red-600';
        btn.disabled = false;
        btn.textContent = 'Odeslat zprávu 🦷';
      }
    } catch {
      status.textContent = 'Chyba sítě. Zkuste to prosím znovu.';
      status.className = 'text-sm mt-2 text-red-600';
      btn.disabled = false;
      btn.textContent = 'Odeslat zprávu 🦷';
    }
  });
</script>
