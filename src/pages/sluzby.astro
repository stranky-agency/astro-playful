---
import Layout from '../layouts/Layout.astro';

const sluzby = [
  {
    emoji: '🎨',
    nazev: 'Kreativní řešení',
    popis: 'Každý projekt řešíme s čerstvým pohledem a spoustou nápadů. Žádné šablony — vymyslíme něco, co skutečně pasuje vám a vašim zákazníkům.',
    zvyrazneny: false,
  },
  {
    emoji: '⚡',
    nazev: 'Rychlé dodání',
    popis: 'Víme, že váš čas je vzácný. Proto pracujeme rychle a efektivně — bez zbytečného zdržování. Termíny bereme vážně a dodržujeme je.',
    zvyrazneny: true,
  },
  {
    emoji: '🤝',
    nazev: 'Osobní přístup',
    popis: 'S každým zákazníkem jednáme jako s kamarádem. Vyslechneme vás, pochopíme vaše potřeby a navrhneme přesně to, co potřebujete.',
    zvyrazneny: false,
  },
  {
    emoji: '🛡️',
    nazev: 'Záruka kvality',
    popis: 'Stojíme za svou prací. Pokud nejste spokojeni, vrátíme se a bez reptání to napravíme. Vaše spokojenost je pro nás na prvním místě.',
    zvyrazneny: false,
  },
];
---
<Layout title="Služby" description="Co všechno umíme a jak vám to může pomoci — s energií a bez zbytečností!">

  <!-- Header -->
  <section class="bg-cream overflow-hidden relative py-20 px-6">
    <div class="absolute top-0 right-0 w-72 h-72 bg-accent rounded-full opacity-20 blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-6">🚀 Co umíme</div>
      <h1 class="text-6xl md:text-7xl font-black text-dark leading-none mb-6 max-w-2xl">
        Služby, které<br/>
        <span class="text-primary-500">vás posunou</span><br/>
        dál!
      </h1>
      <p class="text-gray-600 text-xl max-w-lg leading-relaxed">
        Žádné kecy a zbytečnosti — jen poctivá práce s maximálním nasazením. Přesně takový jsme!
      </p>
    </div>
  </section>

  <!-- Service cards -->
  <section class="section">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-6">
      {sluzby.map((s, i) => (
        <div class={`card p-10 flex flex-col gap-5 relative overflow-hidden ${s.zvyrazneny ? 'bg-primary-500 border-primary-400' : ''}`}>
          {s.zvyrazneny && (
            <div class="absolute top-4 right-4">
              <span class="pill text-xs">✨ Nejoblíbenější</span>
            </div>
          )}
          <div class={`w-18 h-18 rounded-3xl flex items-center justify-center text-5xl ${s.zvyrazneny ? 'bg-white/20' : 'bg-primary-100'}`}
               style="width: 4.5rem; height: 4.5rem;">
            {s.emoji}
          </div>
          <div>
            <h2 class={`text-2xl font-black mb-3 ${s.zvyrazneny ? 'text-white' : 'text-dark'}`}>{s.nazev}</h2>
            <p class={`text-base leading-relaxed ${s.zvyrazneny ? 'text-primary-100' : 'text-gray-500'}`}>{s.popis}</p>
          </div>
          <div class="mt-auto">
            <a href="/kontakt" class={`inline-flex items-center gap-2 font-extrabold text-sm ${s.zvyrazneny ? 'text-white' : 'text-primary-500'}`}>
              Chci tuto službu
              <span class="text-base">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Bonus sekce — co je v ceně -->
  <section class="bg-dark py-20 px-6 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-primary-600 rounded-full opacity-10 translate-x-1/3 translate-y-1/3 blur-2xl"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-8">🎁 Vždy v ceně</div>
      <h2 class="text-4xl font-black text-white mb-10">To vám nikde neřeknou!</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { emoji: '📞', nazev: 'Neomezená komunikace', popis: 'Volejte, pište, ptejte se — jsme tady pro vás, kdykoli potřebujete.' },
          { emoji: '🔄', nazev: 'Opravy zdarma', popis: 'Pokud jsme udělali chybu (stává se to i nejlepším!), napravíme ji bez keců a zadarmo.' },
          { emoji: '📋', nazev: 'Jasná dokumentace', popis: 'Po každé zakázce dostanete přehledný souhrn, co jsme udělali a proč.' },
        ].map(b => (
          <div class="bg-white/5 rounded-4xl p-8 border border-white/10">
            <div class="text-4xl mb-4">{b.emoji}</div>
            <h3 class="font-black text-white text-lg mb-2">{b.nazev}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{b.popis}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="bg-primary-500/10 rounded-5xl p-12 md:p-16 text-center border-2 border-primary-200">
      <div class="text-6xl mb-4">🤔</div>
      <h2 class="text-4xl font-black text-dark mb-4">Stále nevíte, co vybrat?</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto">Zavolejte nám nebo napište — poradíme, co vám nejvíce pomůže, bez jakéhokoli tlaku.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/kontakt" class="btn-primary text-lg px-10 py-4">Zeptejte se nás! 💬</a>
        <a href="/reference" class="btn-outline text-lg px-10 py-4">Zkušenosti zákazníků</a>
      </div>
    </div>
  </section>

</Layout>
