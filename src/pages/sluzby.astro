---
import Layout from '../layouts/Layout.astro';

const sluzby = [
  {
    emoji: '🔍',
    nazev: 'Preventivní péče',
    popis: 'Lepší prevence než léčení. Pravidelné prohlídky a profesionální čistění zubů jsou základem zdravého úsměvu. Přijďte jednou za půl roku — vyplatí se to.',
    zvyrazneny: false,
  },
  {
    emoji: '🦷',
    nazev: 'Ošetření kazu',
    popis: 'Výplně bez stresu. Moderní materiály a šetrný přístup zajistí, že ošetření proběhne co nejrychleji a nejpohodlněji. Kaz včas ošetřen = zub zachráněn.',
    zvyrazneny: true,
  },
  {
    emoji: '🔬',
    nazev: 'Endodoncie',
    popis: 'Zachráníme i zub v problémech. Pokud se infekce dostala hluboko, nemusí to znamenat trhání. Ošetření kořenových kanálků zachrání zub a uleví od bolesti.',
    zvyrazneny: false,
  },
  {
    emoji: '👑',
    nazev: 'Protetika',
    popis: 'Nový zub, nový úsměv. Korunky, můstky nebo snímatelné náhrady — pomůžeme vám vrátit funkčnost i estetiku úsměvu. Každé řešení šijeme na míru.',
    zvyrazneny: false,
  },
  {
    emoji: '✨',
    nazev: 'Estetická stomatologie',
    popis: 'Protože se chcete smát naplno. Bělení zubů, kompozitní fazety nebo kosmetické úpravy — postaráme se, abyste se za svůj úsměv nemuseli stydět.',
    zvyrazneny: false,
  },
  {
    emoji: '👶',
    nazev: 'Dětská stomatologie',
    popis: 'Malí pacienti, velká péče. Víme, jak důležité je, aby děti zubaře nebraly jako strašáka. Přátelský přístup a trpělivost jsou u nás samozřejmostí.',
    zvyrazneny: false,
  },
  {
    emoji: '📡',
    nazev: 'Digitální rentgen',
    popis: 'Moderní technika, méně záření. Digitální rentgen nám umožňuje přesnou diagnostiku s výrazně nižší dávkou záření než klasický film. Lepší obraz, větší bezpečí.',
    zvyrazneny: false,
  },
];
---
<Layout title="Služby" description="Zubní péče od prevence po protetiku. Ošetřujeme dospělé i děti, smluvní VZP, Trutnov.">

  <!-- Header -->
  <section class="bg-cream overflow-hidden relative py-20 px-6">
    <div class="absolute top-0 right-0 w-72 h-72 bg-accent rounded-full opacity-20 blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-6">🦷 Co léčíme</div>
      <h1 class="text-6xl md:text-7xl font-black text-dark leading-none mb-6 max-w-2xl">
        Péče o zuby<br/>
        <span class="text-primary-500">od A do Z!</span>
      </h1>
      <p class="text-gray-600 text-xl max-w-lg leading-relaxed">
        Prevence, ošetření, estetika i dětská stomatologie — v naší ordinaci najdete vše pod jednou střechou.
      </p>
    </div>
  </section>

  <!-- Service cards -->
  <section class="section">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-6">
      {sluzby.map((s, i) => (
        <div class={`card p-10 flex flex-col gap-5 relative overflow-hidden ${s.zvyrazneny ? 'bg-primary-500 border-primary-400' : ''}`}>
          {s.zvyrazneny && (
            <div class="absolute top-4 right-4">
              <span class="pill text-xs">✨ Nejčastější</span>
            </div>
          )}
          <div class={`w-18 h-18 rounded-3xl flex items-center justify-center text-5xl ${s.zvyrazneny ? 'bg-white/20' : 'bg-primary-100'}`}
               style="width: 4.5rem; height: 4.5rem;">
            {s.emoji}
          </div>
          <div>
            <h2 class={`text-2xl font-black mb-3 ${s.zvyrazneny ? 'text-white' : 'text-dark'}`}>{s.nazev}</h2>
            <p class={`text-base leading-relaxed ${s.zvyrazneny ? 'text-primary-100' : 'text-gray-500'}`}>{s.popis}</p>
          </div>
          <div class="mt-auto">
            <a href="/kontakt" class={`inline-flex items-center gap-2 font-extrabold text-sm ${s.zvyrazneny ? 'text-white' : 'text-primary-500'}`}>
              Objednat se
              <span class="text-base">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pojišťovny -->
  <section class="bg-dark py-20 px-6 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-primary-600 rounded-full opacity-10 translate-x-1/3 translate-y-1/3 blur-2xl"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-8">💙 Pojišťovny</div>
      <h2 class="text-4xl font-black text-white mb-10">Smluvní pojišťovny</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { emoji: '🏥', nazev: 'VZP (111)', popis: 'Všeobecná zdravotní pojišťovna — naše hlavní smluvní pojišťovna.' },
          { emoji: '🏥', nazev: 'ČPZP (205)', popis: 'Česká průmyslová zdravotní pojišťovna.' },
          { emoji: '🏥', nazev: 'Ostatní pojišťovny', popis: 'Kontaktujte nás pro ověření, zda ošetřujeme vaši pojišťovnu.' },
        ].map(b => (
          <div class="bg-white/5 rounded-4xl p-8 border border-white/10">
            <div class="text-4xl mb-4">{b.emoji}</div>
            <h3 class="font-black text-white text-lg mb-2">{b.nazev}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{b.popis}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="bg-primary-500/10 rounded-5xl p-12 md:p-16 text-center border-2 border-primary-200">
      <div class="text-6xl mb-4">🦷</div>
      <h2 class="text-4xl font-black text-dark mb-4">Potřebujete poradit?</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto">Zavolejte nebo napište — rádi vysvětlíme, co váš zub potřebuje, a objednáme vás na termín.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/kontakt" class="btn-primary text-lg px-10 py-4">Objednat se! 📅</a>
        <a href="/o-nas" class="btn-outline text-lg px-10 py-4">Náš tým</a>
      </div>
    </div>
  </section>

</Layout>
