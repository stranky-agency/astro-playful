---
import Layout from '../layouts/Layout.astro';

const tym = [
  { jmeno: 'MUDr. Věra Holubcová', role: 'Majitelka ordinace 👑', avatar: '👩‍⚕️', barva: 'bg-primary-500', text: 'white', bio: 'Stomatologie je její vášní. Za 17 let praxe viděla skoro všechno — a vždy se usmívá. Přistupuje ke každému pacientovi osobně a s péčí.' },
  { jmeno: 'MUDr. Eva Černá', role: 'Zubní lékařka 🦷', avatar: '👩‍⚕️', barva: 'bg-white', text: 'dark', bio: 'Specializuje se na estetickou stomatologii a ošetření dospělých. Pracuje přesně, trpělivě a bez zbytečného spěchu.' },
  { jmeno: 'Silvie Forstová', role: 'Instrumentářka 😊', avatar: '👩‍💼', barva: 'bg-accent', text: 'dark', bio: 'Naše úsměvavá instrumentářka. Stará se o plynulý chod ordinace a o to, abyste se vždy cítili vítáni — hned od prvního kroku do čekárny.' },
];

const statistiky = [
  { emoji: '🗓️', hodnota: '17+', popis: 'let praxe' },
  { emoji: '👩‍⚕️', hodnota: '2', popis: 'zkušené lékařky' },
  { emoji: '✅', hodnota: '100%', popis: 'smluvní pojišťovny' },
  { emoji: '📅', hodnota: '5 dní', popis: 'v týdnu pro vás' },
];
---
<Layout title="O nás" description="Poznejte tým zubní ordinace MUDr. Věry Holubcové v Trutnově. 17 let praxe, přátelský přístup.">

  <!-- Hero -->
  <section class="bg-cream overflow-hidden relative py-20 px-6">
    <div class="absolute top-10 right-10 w-80 h-80 bg-primary-200 rounded-full opacity-30 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-20 w-56 h-56 bg-accent rounded-full opacity-30 blur-2xl pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-6">👋 Ahoj, tady jsme!</div>
      <h1 class="text-6xl md:text-7xl font-black text-dark leading-none mb-6 max-w-2xl">
        Malá ordinace,<br/>
        <span class="text-primary-500">velká péče.</span>
      </h1>
      <p class="text-gray-600 text-xl max-w-lg leading-relaxed mb-8">
        Jsme přátelský tým zubních lékařek v Trutnově. Chceme, aby k nám pacienti chodili rádi — ne proto, že musí.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/kontakt" class="btn-primary">Objednat se! 📅</a>
        <a href="/sluzby" class="btn-outline">Co léčíme?</a>
      </div>
    </div>
  </section>

  <!-- Příběh -->
  <section class="section">
    <div class="max-w-6xl mx-auto">
      <div class="pill mb-6">📖 Náš příběh</div>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-4xl font-black text-dark mb-6">Ordinace s historií i srdcem 🦷</h2>
          <p class="text-gray-600 leading-relaxed mb-5 text-lg">
            MUDr. Věra Holubcová otevřela svou zubní ordinaci v Trutnově před více než 17 lety. Od začátku stavěla na jedné věci — přátelském přístupu, který pacienty uklidní místo toho, aby je vyděsil.
          </p>
          <p class="text-gray-600 leading-relaxed text-lg">
            Dnes pracujeme v týmu dvou lékařek a zkušené instrumentářky. Ordinace je vybavena moderní technikou včetně digitálního rentgenu — a přesto zůstáváme rodinnou ordinací, kde vás znají jménem. 😊
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-primary-500/10 rounded-4xl p-8 border-2 border-primary-200">
            <div class="text-4xl mb-3">🎯</div>
            <h3 class="font-black text-dark text-xl mb-2">Naše mise</h3>
            <p class="text-gray-600">Zdravé zuby pro celou rodinu — bez zbytečného strachu a s péčí, která jde nad rámec povinností.</p>
          </div>
          <div class="bg-accent/20 rounded-4xl p-8 border-2 border-accent/30">
            <div class="text-4xl mb-3">💙</div>
            <h3 class="font-black text-dark text-xl mb-2">Náš příslib</h3>
            <p class="text-gray-600">Přistupujeme ke každému pacientovi individuálně — dospělému i dítěti.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tým -->
  <section class="bg-dark py-20 px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-accent rounded-full opacity-10 translate-x-1/3 -translate-y-1/3 blur-2xl"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-6">🤩 Náš tým</div>
      <h2 class="text-4xl font-black text-white mb-10">Lidé za naší ordinací</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {tym.map(clen => (
          <div class={`${clen.barva} rounded-4xl p-8 flex flex-col gap-4 border-2 ${clen.barva === 'bg-white' ? 'border-gray-100' : 'border-transparent'}`}>
            <div class={`w-16 h-16 ${clen.barva === 'bg-primary-500' ? 'bg-white/20' : 'bg-primary-500/10'} rounded-full flex items-center justify-center text-3xl`}>
              {clen.avatar}
            </div>
            <div>
              <h3 class={`font-black text-xl leading-tight ${clen.text === 'white' ? 'text-white' : 'text-dark'}`}>{clen.jmeno}</h3>
              <p class={`text-sm font-bold mt-1 ${clen.text === 'white' ? 'text-primary-200' : 'text-primary-500'}`}>{clen.role}</p>
            </div>
            <p class={`text-sm leading-relaxed ${clen.text === 'white' ? 'text-primary-100' : 'text-gray-500'}`}>{clen.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Statistiky -->
  <section class="section">
    <div class="max-w-6xl mx-auto">
      <div class="pill mb-10 mx-auto w-fit">📊 V číslech</div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {statistiky.map(s => (
          <div class="card text-center py-8">
            <div class="text-5xl mb-3">{s.emoji}</div>
            <div class="text-4xl font-black text-dark mb-2">{s.hodnota}</div>
            <div class="text-gray-400 text-sm font-bold">{s.popis}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="bg-accent/20 rounded-5xl p-12 md:p-20 text-center relative overflow-hidden">
      <div class="absolute top-4 left-8 text-4xl opacity-30 rotate-12">🦷</div>
      <div class="absolute bottom-4 right-8 text-4xl opacity-30 -rotate-12">✨</div>
      <div class="pill mb-6">Rádi vás uvítáme</div>
      <h2 class="text-5xl font-black text-dark mb-4">Přijďte nás navštívit!</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto">Zavolejte nebo napište — objednání je jednoduché a bez zbytečného čekání.</p>
      <a href="/kontakt" class="btn-primary text-lg px-12 py-5">Objednat se 📅</a>
    </div>
  </section>

</Layout>
