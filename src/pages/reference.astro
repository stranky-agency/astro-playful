---
import Layout from '../layouts/Layout.astro';

const duvody = [
  {
    emoji: '🗓️',
    nazev: '17 let zkušeností',
    popis: 'MUDr. Věra Holubcová ordinuje v Trutnově přes 17 let. Za tu dobu ošetřila tisíce pacientů a potkala skoro každý zubní problém, který existuje.',
    barva: 'border-primary-400',
    bg: 'bg-white',
  },
  {
    emoji: '👨‍👩‍👧‍👦',
    nazev: 'Celá rodina vítána',
    popis: 'Ošetřujeme dospělé i děti. Zvládneme první návštěvu batolete i ošetření prarodičů — rodinná ordinace to umí.',
    barva: 'border-accent',
    bg: 'bg-accent/10',
  },
  {
    emoji: '📡',
    nazev: 'Moderní vybavení',
    popis: 'Digitální rentgen, moderní vybavení křesla a kvalitní materiály — investujeme do techniky, abyste vy cítili co nejméně.',
    barva: 'border-primary-300',
    bg: 'bg-primary-50',
  },
  {
    emoji: '✅',
    nazev: 'Smluvní pojišťovny',
    popis: 'Pracujeme se zdravotními pojišťovnami, takže základní péče vás přijde na minimum. Transparentně řekneme předem, co hradí pojišťovna.',
    barva: 'border-primary-400',
    bg: 'bg-white',
  },
  {
    emoji: '🕐',
    nazev: 'Flexibilní hodiny',
    popis: 'Ordinujeme pět dní v týdnu — ráno i odpoledne. Najdeme termín, který vám vyhovuje.',
    barva: 'border-accent',
    bg: 'bg-accent/10',
  },
  {
    emoji: '😊',
    nazev: 'Přátelský tým',
    popis: 'Chceme, abyste k nám chodili bez obav. Dvě zkušené lékařky a milá instrumentářka — vždy uvítáme s úsměvem.',
    barva: 'border-primary-300',
    bg: 'bg-primary-50',
  },
];
---
<Layout title="Proč my" description="Proč si vybrat zubní ordinaci MUDr. Věry Holubcové v Trutnově. 17 let praxe, smluvní VZP, přátelský přístup.">

  <!-- Header -->
  <section class="bg-cream overflow-hidden relative py-20 px-6">
    <div class="absolute top-0 left-0 w-64 h-64 bg-primary-200 rounded-full opacity-30 -translate-x-1/2 -translate-y-1/2 blur-3xl pointer-events-none"></div>
    <div class="max-w-6xl mx-auto relative">
      <div class="pill mb-6">💙 Proč k nám</div>
      <h1 class="text-6xl md:text-7xl font-black text-dark leading-none mb-6 max-w-2xl">
        6 důvodů,<br/>
        <span class="text-primary-500">proč si vybrat</span><br/>
        naši ordinaci.
      </h1>
      <p class="text-gray-600 text-xl max-w-lg leading-relaxed">
        Nemusíte nám věřit na slovo — podívejte se, čím se odlišujeme od jiných ordinací v okolí.
      </p>
    </div>
  </section>

  <!-- Statistiky nahoře -->
  <section class="bg-primary-500 py-10 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-3 gap-6 text-center text-white">
      <div>
        <div class="text-4xl font-black">17+</div>
        <div class="text-primary-200 text-sm mt-1 font-bold">let praxe</div>
      </div>
      <div>
        <div class="text-4xl font-black">2</div>
        <div class="text-primary-200 text-sm mt-1 font-bold">zkušené lékařky</div>
      </div>
      <div>
        <div class="text-4xl font-black">5 dní</div>
        <div class="text-primary-200 text-sm mt-1 font-bold">v týdnu pro vás</div>
      </div>
    </div>
  </section>

  <!-- Důvody karty -->
  <section class="section">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <div class="pill mb-4">Proč si vybrat naši ordinaci</div>
        <h2 class="section-title">Co nás odlišuje</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {duvody.map(d => (
          <div class={`${d.bg} rounded-4xl p-8 border-2 ${d.barva} flex flex-col gap-5`}>
            <div class="text-4xl">{d.emoji}</div>
            <div>
              <h3 class="font-black text-dark text-xl mb-2">{d.nazev}</h3>
              <p class="text-gray-600 leading-relaxed text-sm">{d.popis}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="bg-accent/20 rounded-5xl p-12 md:p-20 text-center relative overflow-hidden">
      <div class="absolute top-6 left-6 text-5xl opacity-20">🦷</div>
      <div class="absolute bottom-6 right-6 text-5xl opacity-20">✨</div>
      <div class="pill mb-6">Přesvědčeni?</div>
      <h2 class="text-5xl font-black text-dark mb-4">Objednejte se k nám!</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto">Zavolejte nebo napište — první návštěva je vždy příjemná. Slibujeme.</p>
      <a href="/kontakt" class="btn-primary text-lg px-12 py-5">Kontaktovat ordinaci 📅</a>
    </div>
  </section>

</Layout>
