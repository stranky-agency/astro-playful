---
interface Props { siteName: string; tagline: string; phone: string; email: string; address: string; }
const { siteName, tagline, phone, email, address } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="bg-dark text-gray-400">
  <div class="max-w-6xl mx-auto px-6 py-14 grid grid-cols-1 md:grid-cols-3 gap-10">
    <div>
      <h3 class="text-white font-black text-xl mb-2">{siteName}</h3>
      <p class="text-gray-500 text-sm">{tagline}</p>
      <div class="mt-4">
        <a href="/kontakt" class="inline-block bg-primary-500 text-white font-bold text-sm px-5 py-2.5 rounded-full hover:bg-primary-600 transition-colors">
          Napište nám 👋
        </a>
      </div>
    </div>
    <div>
      <h4 class="text-white font-extrabold mb-4">Navigace</h4>
      <ul class="space-y-2 text-sm">
        {[['/', 'Úvod'], ['/o-nas', 'O nás'], ['/sluzby', 'Služby'], ['/reference', 'Reference'], ['/kontakt', 'Kontakt']].map(([href, label]) => (
          <li><a href={href} class="hover:text-white transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <h4 class="text-white font-extrabold mb-4">Kontakt</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={`tel:${phone.replace(/\s/g,'')}`} class="hover:text-white transition-colors">{phone}</a></li>
        <li><a href={`mailto:${email}`} class="hover:text-white transition-colors">{email}</a></li>
        <li class="text-gray-500">{address}</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 px-6 py-4 text-center text-xs text-gray-600">
    © {year} {siteName} — s láskou 🧡
  </div>
</footer>
